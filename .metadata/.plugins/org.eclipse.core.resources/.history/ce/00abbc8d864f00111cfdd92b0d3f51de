package web.service;

import java.util.Arrays;
import java.util.HashMap;
import java.util.Map;

public class StudentProfileService {

    // Simulated database of student profiles
    private static final Map<String, StudentProfile> profileDatabase = new HashMap<>();

    static {
        profileDatabase.put("225167346", new StudentProfile(
                "225167346",
                "Palakdeep Kaur",
                Arrays.asList("SIT333", "SIT323", "SIT374", "SIT782"),
                "Pass"
        ));

        profileDatabase.put("000000001", new StudentProfile(
                "000000001",
                "John Smith",
                Arrays.asList("SIT101", "SIT102"),
                "Fail"
        ));
    }

    public static StudentProfile getStudentProfile(String studentId) {
        // Validate input
        if (studentId == null || studentId.trim().isEmpty()) {
            throw new IllegalArgumentException("Student ID cannot be null or empty.");
        }

        return profileDatabase.get(studentId);
    }
}